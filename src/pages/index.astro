---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Pill from '../components/Pill.astro';
import Button from '../components/atoms/Button.astro';
import Hero from '../components/organisms/Hero.astro';
import StatsRow from '../components/organisms/StatsRow.astro';
import FeatureGrid from '../components/organisms/FeatureGrid.astro';
import CTASection from '../components/organisms/CTASection.astro';

const stats = [
  { label: 'Architecture Layers', value: '9' },
  { label: 'AI Agents', value: '20+' },
  { label: 'Skills Installed', value: '66' },
  { label: 'Monthly Cost', value: '€68' },
];

const features = [
  {
    icon: 'lucide:layers',
    title: 'Architecture',
    body: '9-layer stack, unified workflow, domain sessions.',
    href: '/architecture',
  },
  {
    icon: 'lucide:bot',
    title: 'Agent Roster',
    body: '20 agents with category routing and model assignment.',
    href: '/agents',
  },
  {
    icon: 'lucide:route',
    title: 'Model Routing',
    body: 'Multi-model engine with paid + free tier optimization.',
    href: '/models',
  },
  {
    icon: 'lucide:search',
    title: 'Explore',
    body: 'Interactive graph: agents ↔ models ↔ tools ↔ domains.',
    href: '/explore',
  },
  {
    icon: 'lucide:newspaper',
    title: 'News',
    body: 'Tech + cybersecurity news with AI summaries.',
    href: '/news',
  },
  {
    icon: 'lucide:message-square',
    title: 'Ask AI',
    body: 'RAG-powered chat over the entire HPS OS knowledge base. Coming soon.',
  },
];
---

<BaseLayout
  title="HPS AI Hub — The AI Operating System"
  description="Notes from a solo developer combining AI tools across eight domains. Multi-model routing, 100+ agents, 66 skills. One terminal. €68/month."
>
  <Nav />

  <main class="main">

    <Hero
      eyebrow="HPS Proptech & Solutions B.V. · Amsterdam · 2026"
      eyebrowIcon="lucide:sparkles"
    >
      <Fragment slot="title">
        Notes from a solo developer building with <span class="accent">AI</span>.
      </Fragment>
      <Fragment slot="lede">
        A public record of how one developer combines AI tools across eight domains
        without losing taste, budget, or sanity.
      </Fragment>
      <Fragment slot="cta">
        <Button href="/architecture" variant="primary" icon="lucide:arrow-right" iconPosition="end">
          Explore the System
        </Button>
        <Button
          href="https://github.com/Gentleman-Programming"
          variant="ghost"
          icon="lucide:github"
          external
        >
          Star on GitHub
        </Button>
      </Fragment>

      <div class="hero-pills">
        <Pill domain="build">Full-Stack</Pill>
        <Pill domain="build">IoT</Pill>
        <Pill domain="build">ML / DL</Pill>
        <Pill domain="operate">Proptech</Pill>
        <Pill domain="operate">Business Ops</Pill>
        <Pill domain="grow">Analytics</Pill>
        <Pill domain="grow">Marketing</Pill>
        <Pill domain="secure">Cybersecurity</Pill>
      </div>
    </Hero>

    <StatsRow stats={stats} />

    <FeatureGrid
      title="Full architecture deep-dive."
      lede="Each section becomes its own page — interactive components, filterable tables, and an AI-powered assistant."
      features={features}
    />

    <CTASection
      title="One terminal. Nine layers. Zero lock-in."
      lede="Read the docs, fork the repo, run the system on your machine."
    >
      <Fragment slot="cta">
        <Button href="/architecture" variant="primary" icon="lucide:arrow-right" iconPosition="end">
          Start with Architecture
        </Button>
        <Button
          href="https://github.com/Gentleman-Programming"
          variant="ghost"
          icon="lucide:github"
          external
        >
          View Source
        </Button>
      </Fragment>
    </CTASection>

  </main>

  <Footer />
</BaseLayout>

<style>
  .main {
    display: flex;
    flex-direction: column;
  }

  .hero-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-10);
  }
</style>
