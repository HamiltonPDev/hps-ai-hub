---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/atoms/Button.astro';
---

<BaseLayout
  title="Not Found — HPS AI Hub"
  description="404 — this page doesn't exist."
>
  <Nav />

  <main class="main">
    <div class="not-found" data-animate="fade-up">
      <h1 class="code">404</h1>
      <p class="subtitle">Page not found.</p>
      <p class="body">
        Whatever you were looking for isn't here.
        It may have moved, or it may not exist yet.
      </p>
      <div class="actions">
        <Button href="/" variant="primary" icon="lucide:arrow-left">Back to home</Button>
        <Button href="/architecture" variant="ghost" icon="lucide:layers">Architecture</Button>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .main {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
  }

  .not-found {
    max-width: var(--content-max);
    width: 100%;
    margin-inline: auto;
    padding-block: var(--space-48);
    padding-inline: var(--space-6);
    text-align: center;
  }

  .code {
    font-family: var(--font-display);
    font-size: var(--font-size-5xl);
    font-weight: 300;
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    color: var(--color-accent);
    margin: 0 0 var(--space-6);
  }

  .subtitle {
    font-family: var(--font-display);
    font-size: var(--font-size-xl);
    font-weight: 300;
    color: var(--color-text);
    margin: 0 0 var(--space-6);
    line-height: 1.3;
    letter-spacing: var(--tracking-snug);
  }

  .body {
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    line-height: 1.75;
    margin: 0 auto var(--space-10);
    max-width: 36ch;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
  }
</style>
