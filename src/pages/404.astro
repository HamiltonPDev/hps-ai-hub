---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Not Found — HPS AI Hub"
  description="404 — this page doesn't exist."
>
  <Nav />

  <main class="main">
    <div class="not-found" data-animate="fade-up">
      <h1 class="code">404</h1>
      <p class="subtitle">Page not found.</p>
      <p class="body">
        Whatever you were looking for isn't here.
        It may have moved, or it may not exist yet.
      </p>
      <a href="/" class="back-link">← Back to home</a>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── Main wrapper ──────────────────────────────────────────────────── */

  .main {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
  }

  /* ── Not found block ────────────────────────────────────────────────── */

  .not-found {
    max-width: var(--content-max);
    width: 100%;
    margin-inline: auto;
    padding-block: var(--space-48);
    padding-inline: var(--space-6);
    text-align: center;
  }

  .code {
    font-size: var(--font-size-5xl);
    font-weight: 300;
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    color: var(--color-text);
    margin: 0 0 var(--space-6);
  }

  .subtitle {
    font-family: var(--font-body);
    font-size: var(--font-size-xl);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-6);
    line-height: 1.3;
  }

  .body {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    line-height: 1.75;
    margin: 0 0 var(--space-10);
    max-width: 36ch;
    margin-inline: auto;
    margin-bottom: var(--space-10);
  }

  .back-link {
    font-size: var(--font-size-base);
    /* inherits global.css a{} — accent color, underline, hover transition */
  }
</style>
