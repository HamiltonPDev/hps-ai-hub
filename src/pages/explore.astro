---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/atoms/Button.astro';
import Hero from '../components/organisms/Hero.astro';
import CTASection from '../components/organisms/CTASection.astro';
---

<BaseLayout
  title="Explore — HPS AI Hub"
  description="Interactive graph visualization of the HPS AI ecosystem — agents, models, tools, and domains mapped as a connected network."
>
  <Nav />

  <main class="main">

    <Hero eyebrow="04 — Explore" eyebrowIcon="lucide:search">
      <Fragment slot="title">
        <span class="accent">Explore</span>.
      </Fragment>
      <Fragment slot="lede">
        A live graph of the entire HPS AI ecosystem — agents connected to models,
        models connected to domains, domains connected to tools. Every relationship
        made visible and navigable.
      </Fragment>
    </Hero>

    <!-- ── Placeholder ───────────────────────────────────────────────── -->
    <section class="placeholder-section">
      <div class="placeholder-inner">
        <div class="placeholder-card" data-animate="fade-up">
          <p class="placeholder-label">Coming soon</p>
          <h2 class="placeholder-title">Interactive graph</h2>
          <p class="placeholder-body">
            The ecosystem graph is being built as a React island component.
            It will render agents, models, tools, and domains as interactive nodes —
            filterable by domain, clickable for detail panels.
          </p>
          <p class="placeholder-cta">
            In the meantime, the static reference is in the{' '}
            <a href="/architecture">architecture overview</a>.
          </p>
        </div>
      </div>
    </section>

    <CTASection
      title="While the graph is being built."
      lede="Every relationship is already documented — agents, models, domains, skills — in the static reference."
    >
      <Fragment slot="cta">
        <Button href="/architecture" variant="primary" icon="lucide:arrow-right" iconPosition="end">Architecture</Button>
        <Button href="/agents" variant="ghost" icon="lucide:bot">Agent Roster</Button>
      </Fragment>
    </CTASection>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── Main wrapper ──────────────────────────────────────────────────── */

  .main {
    display: flex;
    flex-direction: column;
  }

  /* ── Hero ──────────────────────────────────────────────────────────── */

  .hero {
    border-bottom: 1px solid var(--color-border);
  }

  .hero-inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-block: var(--space-24);
    padding-inline: var(--space-6);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin: 0 0 var(--space-6);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: var(--font-size-5xl);
    font-weight: 300;
    letter-spacing: var(--tracking-tight);
    line-height: 1.05;
    color: var(--color-text);
    margin: 0 0 var(--space-6);
    max-width: 20ch;
  }

  .hero-lede {
    font-size: var(--font-size-md);
    color: var(--color-text-muted);
    max-width: var(--content-max);
    margin: 0;
    line-height: 1.6;
  }

  /* ── Placeholder section ────────────────────────────────────────────── */

  .placeholder-section {
    /* single content area */
  }

  .placeholder-inner {
    max-width: var(--content-max);
    margin-inline: auto;
    padding-block: var(--space-24);
    padding-inline: var(--space-6);
  }

  .placeholder-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-12);
  }

  .placeholder-label {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin: 0 0 var(--space-4);
  }

  .placeholder-title {
    font-size: var(--font-size-2xl);
    font-weight: 300;
    letter-spacing: var(--tracking-snug);
    color: var(--color-text);
    margin: 0 0 var(--space-6);
  }

  .placeholder-body {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    line-height: 1.75;
    margin: 0 0 var(--space-4);
    max-width: var(--content-max);
  }

  .placeholder-cta {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }
</style>
