---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/atoms/Button.astro';
import Hero from '../components/organisms/Hero.astro';
import CTASection from '../components/organisms/CTASection.astro';
import ExploreGraph from '../components/explore/ExploreGraph';
import { buildGraphData } from '../components/explore/buildGraphData';
import type { RawAgent, RawModel } from '../components/explore/buildGraphData';

// ── Read content collections at build time ────────────────────────────────────
const agentEntries = await getCollection('agents');
const modelEntries = await getCollection('models');

const rawAgents: RawAgent[] = agentEntries.map((entry) => ({
  slug: entry.id,
  name: entry.data.name,
  category: entry.data.category,
  role: entry.data.role,
  description: entry.data.description,
  model: entry.data.model,
  modelSlug: entry.data.modelSlug,
  source: entry.data.source,
  domains: entry.data.domains,
  tools: entry.data.tools,
  readOnly: entry.data.readOnly,
}));

const rawModels: RawModel[] = modelEntries.map((entry) => ({
  slug: entry.id,
  name: entry.data.name,
  provider: entry.data.provider,
  tier: entry.data.tier,
  cost: entry.data.cost,
  bestFor: entry.data.bestFor,
  isFree: entry.data.isFree,
  usedBy: entry.data.usedBy,
}));

// ── Compute graph data at build time — island receives serialized props ───────
const { nodes, edges } = buildGraphData(rawAgents, rawModels);
---

<BaseLayout
  title="Explore — HPS AI Hub"
  description="Interactive graph visualization of the HPS AI ecosystem — agents, models, tools, and domains mapped as a connected network."
>
  <Nav />

  <main class="main">

    <Hero eyebrow="04 — Explore" eyebrowIcon="lucide:search">
      <Fragment slot="title">
        <span class="accent">Explore</span>.
      </Fragment>
      <Fragment slot="lede">
        A live graph of the entire HPS AI ecosystem — agents connected to models,
        models connected to domains, domains connected to tools. Every relationship
        made visible and navigable.
      </Fragment>
    </Hero>

    <!-- ── Interactive Graph island ─────────────────────────────────────── -->
    <section class="graph-section" aria-label="Interactive ecosystem graph">
      <ExploreGraph nodes={nodes} edges={edges} client:visible />
    </section>

    <CTASection
      title="While the graph is being built."
      lede="Every relationship is already documented — agents, models, domains, skills — in the static reference."
    >
      <Fragment slot="cta">
        <Button href="/architecture" variant="primary" icon="lucide:arrow-right" iconPosition="end">Architecture</Button>
        <Button href="/agents" variant="ghost" icon="lucide:bot">Agent Roster</Button>
      </Fragment>
    </CTASection>

  </main>

  <Footer />
</BaseLayout>

<style>
  .main {
    display: flex;
    flex-direction: column;
  }

  .graph-section {
    width: 100%;
  }
</style>
