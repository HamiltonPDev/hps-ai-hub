---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/atoms/Button.astro';
import Hero from '../components/organisms/Hero.astro';
import StatsRow from '../components/organisms/StatsRow.astro';
import Terminal from '../components/organisms/Terminal.astro';
import FeatureGrid from '../components/organisms/FeatureGrid.astro';
import CTASection from '../components/organisms/CTASection.astro';

const stats = [
  { label: 'Architecture Layers', value: '9' },
  { label: 'AI Agents', value: '20+' },
  { label: 'Skills Installed', value: '66' },
  { label: 'Monthly Cost', value: '€68' },
];

const features = [
  {
    icon: 'lucide:layers',
    title: '9-Layer Architecture',
    body: 'Unified stack from OS to agents. Each layer documented, audited, and composable.',
  },
  {
    icon: 'lucide:bot',
    title: '20+ AI Agents',
    body: 'Named personas with category routing, model assignment, and explicit lifecycle hooks.',
  },
  {
    icon: 'lucide:route',
    title: 'Model Routing',
    body: 'Multi-model engine. Paid + free tier optimization across Claude, GPT, DeepSeek, Gemini.',
  },
  {
    icon: 'lucide:brain',
    title: '66 Skills Installed',
    body: 'Deterministic skill library — SDD, verification, security review, frontend design, more.',
  },
  {
    icon: 'lucide:shield',
    title: 'Security by Default',
    body: 'OWASP-aligned review agents, secrets detection, least-privilege tool permissions.',
  },
  {
    icon: 'lucide:git-branch',
    title: 'Open by Design',
    body: 'Public record, open-source docs, reproducible workflows. One repo, one terminal.',
  },
];
---

<BaseLayout
  title="HPS AI Hub — Preview (Path B)"
  description="Path B preview: OmO-inspired layout with HPS amber editorial identity."
>
  <Nav />

  <main class="main">

    <Hero
      eyebrow="HPS Proptech & Solutions B.V. · Amsterdam · 2026"
      eyebrowIcon="lucide:sparkles"
    >
      <Fragment slot="title">
        The <span class="accent">AI Operating System</span> for solo developers.
      </Fragment>
      <Fragment slot="lede">
        One terminal. Nine architecture layers. Twenty agents. Sixty-six skills.
        A public record of how one developer combines AI tools across eight domains
        without losing taste, budget, or sanity.
      </Fragment>
      <Fragment slot="cta">
        <Button href="#install" variant="primary" icon="lucide:download">Install HPS AI</Button>
        <Button href="https://github.com/Gentleman-Programming" variant="ghost" icon="lucide:github" external>Star on GitHub</Button>
      </Fragment>
    </Hero>

    <StatsRow stats={stats} />

    <Terminal
      id="install"
      title="One command, nine layers."
      lede="Install the entire HPS AI Operating System in your terminal. No subscriptions to coordinate, no accounts to chain."
    ><span class="term-prompt">$</span> <span class="term-cmd">bunx hps-ai install</span>
<span class="term-ok">✓</span> <span class="term-muted">Detected:</span> macOS 15.3 · fish · bun 1.1.x
<span class="term-ok">✓</span> <span class="term-muted">Installing:</span> 9 layers · 20 agents · 66 skills
<span class="term-ok">✓</span> <span class="term-muted">Configuring:</span> model routing · security hooks
<span class="term-ok">✓</span> <span class="term-muted">Ready in</span> 3.2s

<span class="term-accent">→</span> run <span class="term-cmd">hps start</span> to open your terminal.</Terminal>

    <FeatureGrid
      title="Everything wired from day one."
      lede="Each layer is documented, testable, and composable. Nothing is magic. Every decision has a why, a cost, and a rollback path."
      features={features}
    />

    <CTASection
      title="Ready to ship with AI that actually works?"
      lede="Join the public record. Read the docs, fork the repo, install the system."
    >
      <Fragment slot="cta">
        <Button href="#install" variant="primary" icon="lucide:download">Install Now</Button>
        <Button href="https://github.com/Gentleman-Programming" variant="ghost" icon="lucide:arrow-right" iconPosition="end" external>Read the Docs</Button>
      </Fragment>
    </CTASection>

  </main>

  <Footer />
</BaseLayout>

<style>
  .main {
    display: flex;
    flex-direction: column;
  }
</style>
