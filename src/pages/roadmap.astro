---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/atoms/Button.astro';
import Hero from '../components/organisms/Hero.astro';
import CTASection from '../components/organisms/CTASection.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout
  title="Roadmap — HPS AI Hub"
  description="The real build backlog by phase, plus the March 2026 Claude Code source leak — what HPS OS replicated and what's coming next."
>
  <Nav />

  <main class="main">

    <Hero eyebrow="05 / 12 — What's Coming" eyebrowIcon="lucide:map">
      <Fragment slot="title">
        <span class="accent">Roadmap</span>.
      </Fragment>
      <Fragment slot="lede">
        The real build backlog organized by phase — infrastructure, cybersecurity,
        and site tooling — plus the historical record of the March 2026 Claude Code
        source leak and how HPS OS replicated or diverged from each feature.
      </Fragment>
      <Fragment slot="cta">
        <Button href="/coming-soon" variant="primary" icon="lucide:rocket" iconPosition="end">Priority view</Button>
        <Button href="#cc-leaks" variant="ghost" icon="lucide:scroll">CC Leaks</Button>
      </Fragment>
    </Hero>

    <!-- ── §01 — Build Backlog by Phase ──────────────────────────────── -->
    <section class="content-section" data-animate="fade-up" id="build-backlog">
      <div class="section-inner">
        <h2 class="section-title" data-animate="fade-up">Build backlog by phase</h2>
        <p class="prose">
          Items sourced directly from <code>AGENTS.md</code> — the authority for all
          backlog decisions. For the priority-tagged view (P0/P1/P2 with status badges),
          see <a href="/coming-soon">/coming-soon</a>. This section organizes the same
          items by build phase so the sequence is clear.
        </p>

        <!-- Phase 5 — Infrastructure Builds -->
        <h3 class="subsection-title" data-animate="fade-up">Phase 5 — Infrastructure builds</h3>
        <p class="prose prose-sm">
          Core OS capabilities that make the rest of the system function in daily production.
        </p>
        <ul class="backlog-list" role="list" data-animate="fade-up">

          <li class="backlog-item">
            <span class="backlog-icon" aria-hidden="true">
              <Icon name="lucide:moon-star" />
            </span>
            <div class="backlog-body">
              <span class="backlog-id">B1</span>
              <span class="backlog-name">HPS-Dream / KAIROS Memory Loop</span>
              <span class="backlog-desc">Nightly cron at 03:00 — orient, gather, consolidate, prune. Promotes high-confidence patterns to skills. Replicates the KAIROS pipeline from the CC source leak.</span>
            </div>
          </li>

          <li class="backlog-item">
            <span class="backlog-icon" aria-hidden="true">
              <Icon name="lucide:users" />
            </span>
            <div class="backlog-body">
              <span class="backlog-id">C1</span>
              <span class="backlog-name">Agency-Agents Install</span>
              <span class="backlog-desc">Cherry-pick from the 147-agent agency-agents library — engineering, marketing, sales, product, specialized. Installed under <code>source: agency-agents</code>.</span>
            </div>
          </li>

          <li class="backlog-item">
            <span class="backlog-icon" aria-hidden="true">
              <Icon name="lucide:route" />
            </span>
            <div class="backlog-body">
              <span class="backlog-id">C2</span>
              <span class="backlog-name">OmO Routing Table Config</span>
              <span class="backlog-desc">Explicit routing table mapping OmO categories (ultrabrain, visual-eng, worker, etc.) to the canonical model tier per agent. Closes the gap between documented architecture and runtime.</span>
            </div>
          </li>

          <li class="backlog-item">
            <span class="backlog-icon" aria-hidden="true">
              <Icon name="lucide:brain-circuit" />
            </span>
            <div class="backlog-body">
              <span class="backlog-id">F1</span>
              <span class="backlog-name">Instinct-Based Continuous Learning</span>
              <span class="backlog-desc">PostToolUse hook writes confidence-weighted instincts to Engram on every tool call. HPS-Dream nightly promotes high-confidence instincts into reusable skills.</span>
            </div>
          </li>

        </ul>

        <!-- Cybersecurity Track -->
        <h3 class="subsection-title" data-animate="fade-up">Cybersecurity track — HBO September 2026</h3>
        <p class="prose prose-sm">
          Gated items tied to the HBO cybersecurity program starting September 2026. Full design in
          <code>research/cost-security-analysis-2026-04-17/cybersecurity-strategy.md</code>.
        </p>
        <ul class="backlog-list" role="list" data-animate="fade-up">

          <li class="backlog-item">
            <span class="backlog-icon" aria-hidden="true">
              <Icon name="lucide:shield" />
            </span>
            <div class="backlog-body">
              <span class="backlog-id">S2</span>
              <span class="backlog-name">HPS-Security Skills</span>
              <span class="backlog-desc">Eight domain-specific skills: oracle, yolo, owasp, gdpr, pentest-study, binary-re, incident, ctf. Each ships before September 2026 with conventions, MCPs, and known gotchas.</span>
            </div>
          </li>

          <li class="backlog-item">
            <span class="backlog-icon" aria-hidden="true">
              <Icon name="lucide:cpu" />
            </span>
            <div class="backlog-body">
              <span class="backlog-id">S4</span>
              <span class="backlog-name">hps-security-gemma4 Fine-tune</span>
              <span class="backlog-desc">First fine-tune on a 310-pair curated dataset (Engram exports + NVD CVE + OWASP × HPS + GDPR patterns). Targets Gemma 4 E4B on MLX. Cost-reduction and privacy play — eventually replaces Haiku for HPS-YOLO.</span>
            </div>
          </li>

        </ul>

        <!-- Site & Tooling -->
        <h3 class="subsection-title" data-animate="fade-up">Site &amp; tooling</h3>
        <p class="prose prose-sm">
          Additions to this site and the HPS communication layer.
        </p>
        <ul class="backlog-list" role="list" data-animate="fade-up">

          <li class="backlog-item">
            <span class="backlog-icon" aria-hidden="true">
              <Icon name="lucide:message-square" />
            </span>
            <div class="backlog-body">
              <span class="backlog-id">ASK</span>
              <span class="backlog-name">Ask HPS OS</span>
              <span class="backlog-desc">RAG chat over the entire knowledge base — agents, models, skills, domains, runtime docs. Conversational AI embedded in this site that gives sourced, accurate answers.</span>
            </div>
          </li>

          <li class="backlog-item">
            <span class="backlog-icon" aria-hidden="true">
              <Icon name="lucide:webhook" />
            </span>
            <div class="backlog-body">
              <span class="backlog-id">OPENCLAW</span>
              <span class="backlog-name">OpenClaw</span>
              <span class="backlog-desc">Communication and automation layer. Replaces the Flutter HPS Owner app and the custom HPS-Dream cron with a robust daemon — webhooks, scheduled jobs, and a comms bus between HPS and external services.</span>
            </div>
          </li>

          <li class="backlog-item">
            <span class="backlog-icon" aria-hidden="true">
              <Icon name="lucide:git-fork" />
            </span>
            <div class="backlog-body">
              <span class="backlog-id">GRAPH</span>
              <span class="backlog-name">Interactive Explore Graph</span>
              <span class="backlog-desc">React island visualizing every relationship in the HPS ecosystem — agents ↔ models ↔ tools ↔ domains. Filterable by domain, clickable for detail panels. Replaces the static placeholder on /explore.</span>
            </div>
          </li>

        </ul>

        <div class="callout callout-evergreen" data-animate="fade-up">
          <p>
            Want the priority-tagged view? <a href="/coming-soon">/coming-soon</a> lists
            all nine items above with P0/P1/P2 badges, status, targets, and dependency
            chains.
          </p>
        </div>

      </div>
    </section>

    <!-- ── §05 — What Leaked ───────────────────────────────────────── -->
    <section class="content-section" data-animate="fade-up" id="cc-leaks">
      <div class="section-inner">
        <h2 class="section-title" data-animate="fade-up">What Leaked</h2>
        <p class="prose">
          In March 2026 the Claude Code source was decompiled and published.
          Nine internal features were exposed — some unreleased, some behind
          environment flags, some already shipped. The following cards capture
          each feature's status <strong>as of the March 2026 Claude Code source leak</strong>
          and how HPS OS responded.
        </p>

        <ul class="leak-grid" role="list">

          <!-- 1. KAIROS -->
          <li class="leak-card" data-animate="fade-up">
            <div class="leak-header">
              <h3 class="leak-name">KAIROS</h3>
              <span class="status-badge" data-status="unreleased">Unreleased</span>
            </div>
            <p class="leak-desc">Overnight memory consolidation engine — orient, gather, consolidate, prune. Runs at 03:00 via cron, compresses a week of observations into a structured summary.</p>
            <p class="leak-hps"><strong>HPS replication:</strong> HPS-Dream replicates the full 4-phase pipeline via Engram MCP + nightly cron.</p>
          </li>

          <!-- 2. ULTRAPLAN -->
          <li class="leak-card" data-animate="fade-up">
            <div class="leak-header">
              <h3 class="leak-name">ULTRAPLAN</h3>
              <span class="status-badge" data-status="unreleased">Unreleased</span>
            </div>
            <p class="leak-desc">Multi-phase planning system for complex tasks — decompose, sequence, execute, verify. Internal orchestration layer.</p>
            <p class="leak-hps"><strong>HPS replication:</strong> OmO Prometheus + Metis + Momus provide equivalent planning, execution, and verification phases.</p>
          </li>

          <!-- 3. Coordinator Mode -->
          <li class="leak-card" data-animate="fade-up">
            <div class="leak-header">
              <h3 class="leak-name">Coordinator Mode</h3>
              <span class="status-badge" data-status="env-flag">ENV Flag</span>
            </div>
            <p class="leak-desc">Multi-agent coordination where a primary agent spawns and manages worker agents. Gated behind an environment variable in the leaked source.</p>
            <p class="leak-hps"><strong>HPS replication:</strong> OmO Sisyphus and Atlas agents provide coordinator-worker orchestration.</p>
          </li>

          <!-- 4. SKILL_SEARCH -->
          <li class="leak-card" data-animate="fade-up">
            <div class="leak-header">
              <h3 class="leak-name">SKILL_SEARCH</h3>
              <span class="status-badge" data-status="unreleased">Unreleased</span>
            </div>
            <p class="leak-desc">Semantic vector search over the skill registry — finds relevant skills by embedding similarity rather than keyword match.</p>
            <p class="leak-hps"><strong>HPS replication:</strong> Planned — hps-ml embeddings will power skill search via FTS5 + vector index.</p>
          </li>

          <!-- 5. Daemon Mode -->
          <li class="leak-card" data-animate="fade-up">
            <div class="leak-header">
              <h3 class="leak-name">Daemon Mode</h3>
              <span class="status-badge" data-status="unreleased">Unreleased</span>
            </div>
            <p class="leak-desc">Background agent process that persists between terminal sessions — always-on, event-driven execution.</p>
            <p class="leak-hps"><strong>HPS replication:</strong> OmO Background Agents provide equivalent always-on daemon capability.</p>
          </li>

          <!-- 6. Auto-Dream -->
          <li class="leak-card" data-animate="fade-up">
            <div class="leak-header">
              <h3 class="leak-name">Auto-Dream</h3>
              <span class="status-badge" data-status="unreleased">Unreleased</span>
            </div>
            <p class="leak-desc">Automatic overnight memory processing — the system dreams while you sleep, consolidating context autonomously.</p>
            <p class="leak-hps"><strong>HPS replication:</strong> HPS-Dream nightly cron fires the same pipeline at 03:00 automatically.</p>
          </li>

          <!-- 7. UDS Inbox -->
          <li class="leak-card" data-animate="fade-up">
            <div class="leak-header">
              <h3 class="leak-name">UDS Inbox</h3>
              <span class="status-badge" data-status="unreleased">Unreleased</span>
            </div>
            <p class="leak-desc">Cross-session inter-process communication via Unix domain sockets — agents can message each other without shared filesystem.</p>
            <p class="leak-hps"><strong>HPS replication:</strong> Not yet in HPS OS — planned for Layer C.</p>
          </li>

          <!-- 8. BUDDY -->
          <li class="leak-card" data-animate="fade-up">
            <div class="leak-header">
              <h3 class="leak-name">BUDDY</h3>
              <span class="status-badge" data-status="released">Released</span>
            </div>
            <p class="leak-desc">Easter egg companion mode — a lighter conversational personality embedded in the CLI.</p>
            <p class="leak-hps"><strong>HPS replication:</strong> Easter egg — not critical to the operating system.</p>
          </li>

          <!-- 9. Bridge -->
          <li class="leak-card" data-animate="fade-up">
            <div class="leak-header">
              <h3 class="leak-name">Bridge</h3>
              <span class="status-badge" data-status="released">Released</span>
            </div>
            <p class="leak-desc">Remote control interface — manage CLI sessions from a phone or browser. Bridges the terminal to external clients.</p>
            <p class="leak-hps"><strong>HPS replication:</strong> Planned — Flutter HPS Owner app will provide remote bridge capability.</p>
          </li>

        </ul>

        <!-- Evergreen callout -->
        <div class="callout callout-evergreen" data-animate="fade-up">
          <p>
            HPS OS moved to an API-direct integration strategy after Anthropic
            ended third-party harness access — no intermediary harness layers,
            the Anthropic SDK is the integration point.
            <a href="/news">Read the news entry</a> for context.
          </p>
        </div>

        <!-- Hidden Commands -->
        <h3 class="subsection-title" data-animate="fade-up">Hidden Commands</h3>
        <p class="prose">
          The leaked source also exposed six undocumented slash commands.
          These were not part of the public CLI help output as of the March 2026 leak.
        </p>

        <div class="table-wrapper" data-animate="fade-up">
          <table class="cmd-table">
            <thead>
              <tr>
                <th>Command</th>
                <th>Description</th>
                <th>Leaked status</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><code>/ctx-viz</code></td>
                <td>Visualise context window token usage in a sparkline bar</td>
                <td>Internal only</td>
              </tr>
              <tr>
                <td><code>/btw</code></td>
                <td>Inject a side-note into the conversation without triggering a full turn</td>
                <td>Internal only</td>
              </tr>
              <tr>
                <td><code>/dream</code></td>
                <td>Manually trigger the KAIROS overnight consolidation pipeline</td>
                <td>Internal only</td>
              </tr>
              <tr>
                <td><code>/force-snip</code></td>
                <td>Manually free context tokens by snipping older conversation turns</td>
                <td>Internal only</td>
              </tr>
              <tr>
                <td><code>/bughunter</code></td>
                <td>Adversarial agent that probes your code for edge cases and bugs</td>
                <td>Internal only</td>
              </tr>
              <tr>
                <td><code>/debug-tool-call</code></td>
                <td>Dump the raw tool-call payload for the last tool invocation</td>
                <td>Internal only</td>
              </tr>
            </tbody>
          </table>
        </div>

      </div>
    </section>

    <!-- ── §12 — What's Next ───────────────────────────────────────── -->
    <section class="content-section" data-animate="fade-up">
      <div class="section-inner">
        <h2 class="section-title" data-animate="fade-up">What's Next</h2>
        <p class="prose">
          The roadmap is organised in two tiers. <strong>Layer B</strong> focuses
          on token efficiency and security hardening. <strong>Layer C</strong>
          adds advanced capabilities that extend the operating system's reach.
        </p>

        <h3 class="subsection-title" data-animate="fade-up">Layer B — Token Efficiency &amp; Security</h3>
        <ul class="road-grid" role="list">

          <li class="road-card" data-animate="fade-up">
            <h4 class="road-name">HPS-YOLO</h4>
            <p class="road-layer">Layer 7 — Security</p>
            <p class="road-desc">PreToolUse hook security classifier. Evaluates every tool call before execution and blocks unsafe operations without a confirmation prompt.</p>
          </li>

          <li class="road-card" data-animate="fade-up">
            <h4 class="road-name">Dippy</h4>
            <p class="road-layer">Replaces Bash AST Safety</p>
            <p class="road-desc">Pure Python AST parser with 14K tests. Install-not-build approach — validates shell commands structurally instead of regex matching.</p>
          </li>

          <li class="road-card" data-animate="fade-up">
            <h4 class="road-name">context-mode</h4>
            <p class="road-layer">Replaces /ctx-viz + /btw + /force-snip</p>
            <p class="road-desc">Single plugin that unifies three leaked commands into one coherent context management interface — visualise, annotate, and free tokens.</p>
          </li>

        </ul>

        <h3 class="subsection-title" data-animate="fade-up">Layer C — Advanced Capabilities</h3>
        <ul class="road-grid" role="list">

          <li class="road-card" data-animate="fade-up">
            <h4 class="road-name">UDS Inbox</h4>
            <p class="road-layer">Layer 1 — Runtime</p>
            <p class="road-desc">Cross-session IPC via Unix domain sockets. Agents message each other without shared filesystem — persistent inbox survives restarts.</p>
          </li>

          <li class="road-card" data-animate="fade-up">
            <h4 class="road-name">Bridge</h4>
            <p class="road-layer">Layer 8 — Remote</p>
            <p class="road-desc">Remote control via phone or browser. Manage terminal sessions, approve tool calls, and review diffs from the Flutter HPS Owner app.</p>
          </li>

          <li class="road-card" data-animate="fade-up">
            <h4 class="road-name">/bughunter</h4>
            <p class="road-layer">Layer 2 — Orchestration</p>
            <p class="road-desc">Adversarial agent that probes your code for edge cases, race conditions, and logic bugs. Runs in parallel with normal development.</p>
          </li>

          <li class="road-card" data-animate="fade-up">
            <h4 class="road-name">SKILL_SEARCH</h4>
            <p class="road-layer">Layer 2 — Orchestration</p>
            <p class="road-desc">Semantic vector search over the skill registry. Finds relevant skills by embedding similarity — powered by hps-ml and FTS5.</p>
          </li>

          <li class="road-card" data-animate="fade-up">
            <h4 class="road-name">Injection Defense</h4>
            <p class="road-layer">Layer 7 — Security</p>
            <p class="road-desc">Six-layer prompt injection defense system. Detects and blocks injection attempts at input, tool-call, and output stages.</p>
          </li>

          <li class="road-card" data-animate="fade-up">
            <h4 class="road-name">/force-snip</h4>
            <p class="road-layer">Layer 4 — Memory</p>
            <p class="road-desc">Manual context token freeing. Snip older conversation turns to reclaim context window space — also unified into context-mode (Layer B).</p>
          </li>

        </ul>

      </div>
    </section>

    <CTASection
      title="From backlog to shipped features."
      lede="Every item traces back to AGENTS.md. The architecture documents every layer the backlog builds on."
    >
      <Fragment slot="cta">
        <Button href="/coming-soon" variant="primary" icon="lucide:rocket" iconPosition="end">Priority queue</Button>
        <Button href="/architecture" variant="ghost" icon="lucide:layers">Architecture</Button>
        <Button href="/news" variant="ghost" icon="lucide:newspaper">Changelog</Button>
      </Fragment>
    </CTASection>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── Main wrapper ──────────────────────────────────────────────────── */

  /* ── Build backlog list ────────────────────────────────────────────── */

  .backlog-list {
    list-style: none;
    margin: 0 0 var(--space-8);
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .backlog-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: border-color var(--duration-quick) var(--ease-standard);
  }

  .backlog-item:hover {
    border-color: var(--color-border-strong);
  }

  .backlog-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-sm);
    background: color-mix(in oklch, var(--color-accent) 10%, transparent);
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .backlog-icon :global([data-icon]) {
    width: 16px;
    height: 16px;
  }

  .backlog-body {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2);
    flex: 1;
  }

  .backlog-id {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-accent);
    background: color-mix(in oklch, var(--color-accent) 10%, transparent);
    border: 1px solid color-mix(in oklch, var(--color-accent) 25%, transparent);
    padding: var(--space-0-5) var(--space-2);
    border-radius: var(--radius-full);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .backlog-name {
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-text);
    flex-shrink: 0;
  }

  .backlog-desc {
    width: 100%;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-top: var(--space-1);
  }

  .backlog-desc code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    padding: 0.1em 0.3em;
    border-radius: var(--radius-sm);
    color: var(--color-text);
  }

  .prose-sm {
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-4);
  }

  .prose a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .main {
    display: flex;
    flex-direction: column;
  }

  /* ── Content sections ──────────────────────────────────────────────── */

  .content-section {
    border-bottom: 1px solid var(--color-border);
  }

  .section-inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-block: var(--space-24);
    padding-inline: var(--space-6);
  }

  .section-title {
    font-size: var(--font-size-2xl);
    font-weight: 300;
    letter-spacing: var(--tracking-snug);
    color: var(--color-text);
    margin: 0 0 var(--space-12);
  }

  .subsection-title {
    font-size: var(--font-size-lg);
    font-weight: 400;
    color: var(--color-text);
    margin: var(--space-16) 0 var(--space-8);
  }

  /* ── Prose ─────────────────────────────────────────────────────────── */

  .prose {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    max-width: var(--content-max);
    margin: 0 0 var(--space-8);
    line-height: 1.7;
  }

  .prose strong {
    color: var(--color-text);
    font-weight: 600;
  }

  /* ── Leak grid — feature cards ─────────────────────────────────────── */

  .leak-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-4);
    list-style: none;
    margin: 0 0 var(--space-12);
    padding: 0;
  }

  .leak-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    transition: border-color var(--duration-quick) var(--ease-standard);
  }

  .leak-card:hover {
    border-color: var(--color-border-strong);
  }

  .leak-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .leak-name {
