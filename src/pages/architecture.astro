---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import WorkflowDiagram from '../components/WorkflowDiagram.astro';
import Button from '../components/atoms/Button.astro';
import Hero from '../components/organisms/Hero.astro';
import CTASection from '../components/organisms/CTASection.astro';
import { getCollection } from 'astro:content';
import { buildSlugSet, assertXref, assertXrefList } from '../lib/xref';

// ── Collections ──────────────────────────────────────────────────────────
const layers = (await getCollection('layers')).sort((a, b) => a.data.index - b.data.index);
const agents = await getCollection('agents');
const models = await getCollection('models');

// Domains — empty until Wave-3; guard with try/catch
let domains: Awaited<ReturnType<typeof getCollection>> = [];
try {
  domains = await getCollection('domains');
} catch {
  // domains collection empty until Wave-3
}

// ── Cross-reference validation ───────────────────────────────────────────
const agentSet = buildSlugSet(agents);
const modelSet = buildSlugSet(models);

for (const layer of layers) {
  if (layer.data.model) {
    assertXref(`layers/${layer.id}`, 'model', layer.data.model, modelSet, 'models');
  }
  assertXrefList(`layers/${layer.id}`, 'relatedAgents', layer.data.relatedAgents, agentSet, 'agents');
}

// ── Agent name lookup (for pills) ────────────────────────────────────────
const agentNameMap = new Map(agents.map((a) => [a.id.replace(/\.md$/, ''), a.data.name]));

// ── Unified ASCII diagram (all layers combined) ──────────────────────────
const unifiedDiagram = layers
  .filter((l) => l.data.diagramAscii)
  .map((l) => l.data.diagramAscii!.trimEnd())
  .join('\n\n────────────────────────────────────────────────────────────────────\n\n');

const fullDiagram = `╔══════════════════════════════════════════════════════════════════════╗
║                    HPS AI OPERATING SYSTEM v2                        ║
╚══════════════════════════════════════════════════════════════════════╝

${unifiedDiagram}`;
---

<BaseLayout
  title="Architecture — HPS AI Hub"
  description="The 9-layer architecture of the HPS AI Operating System. From models through orchestration to remote clients — every component has a single responsibility."
>
  <Nav />

  <main class="main">

    <Hero eyebrow="01 — Architecture" eyebrowIcon="lucide:layers">
      <Fragment slot="title">
        The full stack, <span class="accent">layer by layer</span>.
      </Fragment>
      <Fragment slot="lede">
        Every component has a single responsibility. Nothing overlaps. Nothing is missing.
      </Fragment>
    </Hero>

    <!-- ── Layer list ──────────────────────────────────────────────── -->
    <section class="content-section">
      <div class="content-inner">

        <h2 class="section-title" data-animate="fade-up">The nine layers</h2>

        <ol class="layer-list" role="list">
          {layers.map((layer) => (
            <li class="layer-item" data-animate="fade-up">
              <span class="layer-index">{String(layer.data.index).padStart(2, '0')}</span>
              <div class="layer-body">
                <h3 class="layer-name">{layer.data.name}</h3>
                <p class="layer-desc">{layer.data.responsibility}</p>
                {layer.data.components.length > 0 && (
                  <ul class="layer-components" role="list">
                    {layer.data.components.map((c: string) => (
                      <li class="layer-component">{c}</li>
                    ))}
                  </ul>
                )}
                {layer.data.relatedAgents.length > 0 && (
                  <div class="layer-agents">
                    {layer.data.relatedAgents.map((slug: string) => (
                      <span class="layer-agent-pill">{agentNameMap.get(slug) ?? slug}</span>
                    ))}
                  </div>
                )}
              </div>
            </li>
          ))}
        </ol>

      </div>
    </section>

    <!-- ── Unified architecture diagram ────────────────────────────── -->
    <section class="content-section content-section--bordered" data-animate="fade-up">
      <div class="content-inner">
        <h2 class="section-title" data-animate="fade-up">Architecture diagram</h2>
        <WorkflowDiagram title="HPS AI Operating System v2">
          {fullDiagram}
        </WorkflowDiagram>
      </div>
    </section>

    <CTASection
      title="Go deeper into the system."
      lede="From the agent roster to the model routing engine — every layer links out."
    >
      <Fragment slot="cta">
        <Button href="/agents" variant="primary" icon="lucide:arrow-right" iconPosition="end">Agent Roster</Button>
        <Button href="/models" variant="ghost" icon="lucide:route">Model Routing</Button>
        <Button href="/explore" variant="ghost" icon="lucide:search">Explore Graph</Button>
      </Fragment>
    </CTASection>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── Main wrapper ──────────────────────────────────────────────────── */

  .main {
    display: flex;
    flex-direction: column;
  }

  /* ── Hero ──────────────────────────────────────────────────────────── */

  .hero {
    border-bottom: 1px solid var(--color-border);
  }

  .hero-inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-block: var(--space-24);
    padding-inline: var(--space-6);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin: 0 0 var(--space-6);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: var(--font-size-5xl);
    font-weight: 300;
    letter-spacing: var(--tracking-tight);
    line-height: 1.05;
    color: var(--color-text);
    margin: 0 0 var(--space-6);
    max-width: 20ch;
  }

  .hero-lede {
    font-size: var(--font-size-md);
    color: var(--color-text-muted);
    max-width: var(--content-max);
    margin: 0;
    line-height: 1.6;
  }

  /* ── Content sections ──────────────────────────────────────────────── */

  .content-section {
    /* prose — content-max width */
  }

  .content-section--bordered {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .content-inner {
    max-width: var(--content-max);
    margin-inline: auto;
    padding-block: var(--space-24);
    padding-inline: var(--space-6);
  }

  .section-title {
    font-size: var(--font-size-2xl);
    font-weight: 300;
    letter-spacing: var(--tracking-snug);
    color: var(--color-text);
    margin: 0 0 var(--space-10);
  }

  /* ── Layer list ─────────────────────────────────────────────────────── */

  .layer-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .layer-item {
    display: flex;
    gap: var(--space-6);
    align-items: flex-start;
  }

  .layer-index {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-subtle);
    flex-shrink: 0;
    padding-top: 0.2em;
  }

  .layer-body {
    flex: 1;
  }

  .layer-name {
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    font-weight: 500;
    color: var(--color-text);
    margin: 0 0 var(--space-2);
    line-height: 1.3;
  }

  .layer-desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.65;
  }

  /* ── Components (inline tag list below description) ─────────────────── */

  .layer-components {
    list-style: none;
    margin: var(--space-3) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .layer-component {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--color-text-subtle);
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-2);
    white-space: nowrap;
  }

  /* ── Agent pills (below components) ─────────────────────────────────── */

  .layer-agents {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-3);
  }

  .layer-agent-pill {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-full);
    padding: var(--space-1) var(--space-3);
    white-space: nowrap;
  }

  /* ── Nav list ───────────────────────────────────────────────────────── */

  .nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .nav-list li {
    font-size: var(--font-size-base);
  }
</style>
