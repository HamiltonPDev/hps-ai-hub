---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Architecture — HPS AI Hub"
  description="The 9-layer architecture powering HPS AI Hub. From hardware and infrastructure through to the AI agent layer — a unified workflow for solo development at scale."
>
  <Nav />

  <main class="main">

    <!-- ── Hero ─────────────────────────────────────────────────────── -->
    <section class="hero" data-animate="fade-up">
      <div class="hero-inner">
        <p class="eyebrow">01 — Architecture</p>
        <h1 class="hero-title">The full stack,<br />layer by layer.</h1>
        <p class="hero-lede">
          Nine layers from hardware to AI agent orchestration.
          Each layer has a single responsibility. Together they make solo development at scale possible.
        </p>
      </div>
    </section>

    <!-- ── Layer overview ───────────────────────────────────────────── -->
    <section class="content-section">
      <div class="content-inner">

        <h2 class="section-title" data-animate="fade-up">The nine layers</h2>

        <ol class="layer-list" role="list">
          <li class="layer-item" data-animate="fade-up">
            <span class="layer-index">01</span>
            <div class="layer-body">
              <h3 class="layer-name">Infrastructure & Hardware</h3>
              <p class="layer-desc">
                MacBook Pro M4 Pro · NixOS VM fleet · Docker Compose stacks.
                The physical and virtual substrate everything runs on.
              </p>
            </div>
          </li>

          <li class="layer-item" data-animate="fade-up">
            <span class="layer-index">02</span>
            <div class="layer-body">
              <h3 class="layer-name">Shell & Terminal Environment</h3>
              <p class="layer-desc">
                Fish shell · Zellij multiplexer · LazyVim editor.
                One terminal. Every workflow starts here.
              </p>
            </div>
          </li>

          <li class="layer-item" data-animate="fade-up">
            <span class="layer-index">03</span>
            <div class="layer-body">
              <h3 class="layer-name">Version Control & Automation</h3>
              <p class="layer-desc">
                Git · GitHub CLI · conventional commits · pre-commit hooks.
                Clean history enforced at the commit gate.
              </p>
            </div>
          </li>

          <li class="layer-item" data-animate="fade-up">
            <span class="layer-index">04</span>
            <div class="layer-body">
              <h3 class="layer-name">Package & Dependency Management</h3>
              <p class="layer-desc">
                Nix home-manager · Homebrew · pnpm · uv.
                Reproducible environments, pinned dependencies.
              </p>
            </div>
          </li>

          <li class="layer-item" data-animate="fade-up">
            <span class="layer-index">05</span>
            <div class="layer-body">
              <h3 class="layer-name">Data Layer</h3>
              <p class="layer-desc">
                Supabase (Postgres) · SQLite for local work · Redis for session state.
                Right database for the right job.
              </p>
            </div>
          </li>

          <li class="layer-item" data-animate="fade-up">
            <span class="layer-index">06</span>
            <div class="layer-body">
              <h3 class="layer-name">API & Backend Services</h3>
              <p class="layer-desc">
                Hono · FastAPI · n8n automation engine.
                Minimal surfaces. Each service does one thing.
              </p>
            </div>
          </li>

          <li class="layer-item" data-animate="fade-up">
            <span class="layer-index">07</span>
            <div class="layer-body">
              <h3 class="layer-name">Frontend Applications</h3>
              <p class="layer-desc">
                Astro · Next.js 15 · Angular 19.
                Static-first where possible, React islands for interactivity.
              </p>
            </div>
          </li>

          <li class="layer-item" data-animate="fade-up">
            <span class="layer-index">08</span>
            <div class="layer-body">
              <h3 class="layer-name">Model Routing Layer</h3>
              <p class="layer-desc">
                Claude Opus · Claude Sonnet · Claude Haiku · Gemini · GPT-4o · Groq (free tier).
                Category-based routing: the right model for the right task.
              </p>
            </div>
          </li>

          <li class="layer-item" data-animate="fade-up">
            <span class="layer-index">09</span>
            <div class="layer-body">
              <h3 class="layer-name">AI Agent Orchestration</h3>
              <p class="layer-desc">
                20 specialized agents · 66 skills · SDD workflow · Engram persistent memory.
                The intelligence layer that coordinates everything above it.
              </p>
            </div>
          </li>
        </ol>

      </div>
    </section>

    <!-- ── Unified workflow ──────────────────────────────────────────── -->
    <section class="content-section content-section--bordered">
      <div class="content-inner">

        <h2 class="section-title" data-animate="fade-up">Unified workflow</h2>
        <p class="prose" data-animate="fade-up">
          Every feature, fix, and exploration runs through the same pipeline:
          intent → spec → design → tasks → apply → verify → archive.
          This is Spec-Driven Development (SDD) — a planning layer that sits
          above the code and keeps the AI in the executor seat, not the decision seat.
        </p>

        <p class="prose" data-animate="fade-up">
          The workflow is enforced by Claude Code agents, not by willpower.
          Skipping a phase isn't possible without explicitly overriding the orchestrator.
          That friction is intentional.
        </p>

        <h2 class="section-title section-title--spaced" data-animate="fade-up">Cost model</h2>
        <p class="prose" data-animate="fade-up">
          The entire stack runs for €68/month. That includes API costs across
          three paid model tiers plus free-tier fallbacks for non-critical tasks.
          Opus is reserved for architecture decisions. Haiku handles automation.
          Sonnet does everything in between.
        </p>

        <p class="prose" data-animate="fade-up">
          No VC funding. No team. One developer, one terminal, eight domains.
        </p>

      </div>
    </section>

    <!-- ── Navigation ────────────────────────────────────────────────── -->
    <section class="content-section">
      <div class="content-inner">
        <h2 class="section-title" data-animate="fade-up">Go deeper</h2>
        <ul class="nav-list" role="list">
          <li data-animate="fade-up"><a href="/agents">Agent Roster →</a></li>
          <li data-animate="fade-up"><a href="/models">Model Routing →</a></li>
          <li data-animate="fade-up"><a href="/explore">Explore the graph →</a></li>
        </ul>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── Main wrapper ──────────────────────────────────────────────────── */

  .main {
    display: flex;
    flex-direction: column;
  }

  /* ── Hero ──────────────────────────────────────────────────────────── */

  .hero {
    border-bottom: 1px solid var(--color-border);
  }

  .hero-inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-block: var(--space-24);
    padding-inline: var(--space-6);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin: 0 0 var(--space-6);
  }

  .hero-title {
    font-size: var(--font-size-5xl);
    font-weight: 300;
    letter-spacing: var(--tracking-tight);
    line-height: 1.05;
    color: var(--color-text);
    margin: 0 0 var(--space-6);
    max-width: 20ch;
  }

  .hero-lede {
    font-size: var(--font-size-md);
    color: var(--color-text-muted);
    max-width: var(--content-max);
    margin: 0;
    line-height: 1.6;
  }

  /* ── Content sections ──────────────────────────────────────────────── */

  .content-section {
    /* prose — content-max width */
  }

  .content-section--bordered {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .content-inner {
    max-width: var(--content-max);
    margin-inline: auto;
    padding-block: var(--space-24);
    padding-inline: var(--space-6);
  }

  .section-title {
    font-size: var(--font-size-2xl);
    font-weight: 300;
    letter-spacing: var(--tracking-snug);
    color: var(--color-text);
    margin: 0 0 var(--space-10);
  }

  .section-title--spaced {
    margin-top: var(--space-16);
  }

  .prose {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    line-height: 1.75;
    margin: 0 0 var(--space-6);
    max-width: var(--content-max);
  }

  /* ── Layer list ─────────────────────────────────────────────────────── */

  .layer-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .layer-item {
    display: flex;
    gap: var(--space-6);
    align-items: flex-start;
  }

  .layer-index {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-subtle);
    flex-shrink: 0;
    padding-top: 0.2em;
  }

  .layer-body {
    flex: 1;
  }

  .layer-name {
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    font-weight: 500;
    color: var(--color-text);
    margin: 0 0 var(--space-2);
    line-height: 1.3;
  }

  .layer-desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.65;
  }

  /* ── Nav list ───────────────────────────────────────────────────────── */

  .nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .nav-list li {
    font-size: var(--font-size-base);
  }
</style>
