---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const models = await getCollection('models');

// Sort by category for display grouping
const sorted = [...models].sort((a, b) =>
  a.data.category.localeCompare(b.data.category)
);
---

<BaseLayout
  title="Model Routing — HPS AI Hub"
  description="Multi-model decision engine powering HPS AI Hub. Opus for architecture, Sonnet for implementation, Haiku for automation, free tiers for non-critical tasks."
>
  <Nav />

  <main class="main">

    <!-- ── Hero ─────────────────────────────────────────────────────── -->
    <section class="hero" data-animate="fade-up">
      <div class="hero-inner">
        <p class="eyebrow">03 — Model Routing</p>
        <h1 class="hero-title">The decision engine.</h1>
        <p class="hero-lede">
          Not every task deserves the same model. Category routing fires the right
          model for the right task — maximizing quality where it matters,
          minimizing cost where it doesn't.
        </p>
      </div>
    </section>

    <!-- ── Routing strategy ──────────────────────────────────────────── -->
    <section class="strategy-section">
      <div class="content-inner">
        <h2 class="section-title" data-animate="fade-up">Routing strategy</h2>
        <p class="prose" data-animate="fade-up">
          Three paid tiers plus free fallbacks. The routing rule is simple:
          match task complexity to model capability. Architecture decisions → Opus.
          Implementation → Sonnet. Automation and routine tasks → Haiku.
          Non-critical summarization → free tier (Groq / Gemini Flash).
        </p>
        <p class="prose" data-animate="fade-up">
          Total monthly cost: €68. No wasted tokens on commodity tasks.
          No under-powered models on decisions that matter.
        </p>
      </div>
    </section>

    <!-- ── Model list ────────────────────────────────────────────────── -->
    <section class="models-section">
      <div class="models-inner">
        <h2 class="section-title" data-animate="fade-up">Model roster</h2>

        {sorted.length === 0 ? (
          <p class="empty-state" data-animate="fade-up">
            Model definitions are being ported from the master reference document.
            See the <a href="/architecture">architecture page</a> for the current routing overview.
          </p>
        ) : (
          <ul class="model-grid" role="list">
            {sorted.map((model) => (
              <li class="model-card" data-animate="fade-up">
                <div class="model-header">
                  <span class="model-name">{model.data.name}</span>
                  <span class="model-provider">{model.data.provider}</span>
                </div>
                <p class="model-category">{model.data.category}</p>
                <p class="model-best-for">{model.data.bestFor}</p>
                <p class="model-cost">{model.data.cost}</p>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>

    <!-- ── Tier overview ─────────────────────────────────────────────── -->
    <section class="tiers-section">
      <div class="content-inner">
        <h2 class="section-title" data-animate="fade-up">Tier overview</h2>
        <ul class="tier-list" role="list">
          <li class="tier-item" data-animate="fade-up">
            <span class="tier-label">Tier 1 — Architecture</span>
            <p class="tier-desc">
              Opus-class models. Orchestration, design decisions, code review of critical paths.
              Highest cost per token. Reserved for tasks where quality directly affects system integrity.
            </p>
          </li>
          <li class="tier-item" data-animate="fade-up">
            <span class="tier-label">Tier 2 — Implementation</span>
            <p class="tier-desc">
              Sonnet-class models. Feature development, debugging, test writing, PR generation.
              The daily driver. Balances quality and cost across a broad task surface.
            </p>
          </li>
          <li class="tier-item" data-animate="fade-up">
            <span class="tier-label">Tier 3 — Automation</span>
            <p class="tier-desc">
              Haiku-class models. Commit message generation, file renaming, boilerplate scaffolding.
              Low cost per call. High call volume. Handles the mechanical layer.
            </p>
          </li>
          <li class="tier-item" data-animate="fade-up">
            <span class="tier-label">Free tier</span>
            <p class="tier-desc">
              Groq (Llama) and Gemini Flash for summarization, news digests, non-critical drafts.
              Zero marginal cost. Used wherever quality tolerance allows.
            </p>
          </li>
        </ul>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── Main wrapper ──────────────────────────────────────────────────── */

  .main {
    display: flex;
    flex-direction: column;
  }

  /* ── Hero ──────────────────────────────────────────────────────────── */

  .hero {
    border-bottom: 1px solid var(--color-border);
  }

  .hero-inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-block: var(--space-24);
    padding-inline: var(--space-6);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin: 0 0 var(--space-6);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: var(--font-size-5xl);
    font-weight: 300;
    letter-spacing: var(--tracking-tight);
    line-height: 1.05;
    color: var(--color-text);
    margin: 0 0 var(--space-6);
    max-width: 20ch;
  }

  .hero-lede {
    font-size: var(--font-size-md);
    color: var(--color-text-muted);
    max-width: var(--content-max);
    margin: 0;
    line-height: 1.6;
  }

  /* ── Shared content inner ───────────────────────────────────────────── */

  .content-inner {
    max-width: var(--content-max);
    margin-inline: auto;
    padding-block: var(--space-24);
    padding-inline: var(--space-6);
  }

  .section-title {
    font-size: var(--font-size-2xl);
    font-weight: 300;
    letter-spacing: var(--tracking-snug);
    color: var(--color-text);
    margin: 0 0 var(--space-10);
  }

  .prose {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    line-height: 1.75;
    margin: 0 0 var(--space-6);
  }

  /* ── Strategy section ───────────────────────────────────────────────── */

  .strategy-section {
    border-bottom: 1px solid var(--color-border);
  }

  /* ── Models section ─────────────────────────────────────────────────── */

  .models-section {
    border-bottom: 1px solid var(--color-border);
  }

  .models-inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-block: var(--space-24);
    padding-inline: var(--space-6);
  }

  .empty-state {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    max-width: var(--content-max);
    line-height: 1.65;
  }

  .model-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (min-width: 640px) {
    .model-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .model-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .model-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    transition: border-color var(--duration-quick) var(--ease-standard);
  }

  .model-card:hover {
    border-color: var(--color-border-strong);
  }

  .model-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .model-name {
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.3;
  }

  .model-provider {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--color-text-subtle);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    flex-shrink: 0;
  }

  .model-category {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--color-text-subtle);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    margin: 0 0 var(--space-2);
  }

  .model-best-for {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3);
    line-height: 1.5;
  }

  .model-cost {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--color-text-subtle);
    margin: 0;
  }

  /* ── Tiers section ──────────────────────────────────────────────────── */

  .tiers-section {
    /* last section */
  }

  .tier-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  .tier-item {
    /* no border — prose rhythm separation only */
  }

  .tier-label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .tier-desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.7;
    max-width: var(--content-max);
  }
</style>
