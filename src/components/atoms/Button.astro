---
import { Icon } from 'astro-icon/components';

interface Props {
  href?: string;
  variant?: 'primary' | 'ghost';
  icon?: string;
  iconPosition?: 'start' | 'end';
  external?: boolean;
  class?: string;
}

const {
  href,
  variant = 'primary',
  icon,
  iconPosition = 'start',
  external = false,
  class: className = '',
} = Astro.props;

const Tag = href ? 'a' : 'button';
const extraAttrs = external
  ? { rel: 'noopener noreferrer', target: '_blank' }
  : {};
---

<Tag
  class:list={['btn', `btn--${variant}`, className]}
  href={href}
  {...extraAttrs}
>
  {icon && iconPosition === 'start' && <Icon name={icon} />}
  <span><slot /></span>
  {icon && iconPosition === 'end' && <Icon name={icon} />}
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    height: 3rem;
    padding-inline: var(--space-6);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    border: 1px solid transparent;
    cursor: pointer;
    transition:
      background-color var(--duration-quick) var(--ease-standard),
      border-color var(--duration-quick) var(--ease-standard),
      color var(--duration-quick) var(--ease-standard);
  }

  .btn :global([data-icon]) {
    width: 18px;
    height: 18px;
  }

  .btn--primary {
    background: var(--color-accent);
    color: var(--primitive-neutral-0);
  }

  .btn--primary:hover {
    background: var(--color-accent-hover);
    color: var(--primitive-neutral-0);
  }

  .btn--ghost {
    background: transparent;
    color: var(--color-text);
    border-color: var(--color-border-strong);
  }

  .btn--ghost:hover {
    background: var(--color-surface);
    color: var(--color-text);
    border-color: var(--color-accent);
  }
</style>
