---
import { Icon } from 'astro-icon/components';

interface Props {
  icon: string;
  title: string;
  href?: string;
}

const { icon, title, href } = Astro.props;
const Tag = href ? 'a' : 'article';
---

<Tag class:list={['feature-card', { 'feature-card--link': href }]} href={href} data-animate="fade-up">
  <div class="feature-icon">
    <Icon name={icon} />
  </div>
  <h3 class="feature-title">{title}</h3>
  <p class="feature-body"><slot /></p>
</Tag>

<style>
  .feature-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    transition: border-color var(--duration-quick) var(--ease-standard);
    display: block;
  }

  .feature-card:hover {
    border-color: var(--color-accent);
  }

  .feature-card--link {
    text-decoration: none;
    color: inherit;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-md);
    background: color-mix(in oklch, var(--color-accent) 10%, transparent);
    color: var(--color-accent);
    margin-bottom: var(--space-6);
  }

  .feature-icon :global([data-icon]) {
    width: 22px;
    height: 22px;
  }

  .feature-title {
    font-family: var(--font-display);
    font-size: var(--font-size-lg);
    font-weight: 400;
    color: var(--color-text);
    margin: 0 0 var(--space-2);
    letter-spacing: var(--tracking-snug);
    line-height: 1.3;
  }

  .feature-body {
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.65;
  }
</style>
