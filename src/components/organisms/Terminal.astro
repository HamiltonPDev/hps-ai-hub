---
import TerminalChrome from '../molecules/TerminalChrome.astro';

interface Props {
  title?: string;
  chromeTitle?: string;
  lede?: string;
  id?: string;
}

const { title, chromeTitle, lede, id } = Astro.props;
---

<section class="terminal-section" id={id}>
  <div class="terminal-inner">
    {title && (
      <h2 class="section-title" data-animate="fade-up">{title}</h2>
    )}
    {lede && (
      <p class="section-lede" data-animate="fade-up">{lede}</p>
    )}

    <div class="terminal" data-animate="fade-up">
      <TerminalChrome title={chromeTitle} />
      <pre class="terminal-body"><slot /></pre>
    </div>
  </div>
</section>

<style is:global>
  .terminal .term-prompt { color: var(--color-text-subtle); }
  .terminal .term-cmd    { color: var(--color-accent); }
  .terminal .term-ok     { color: var(--primitive-green-500); }
  .terminal .term-warn   { color: oklch(75% 0.15 80); }
  .terminal .term-muted  { color: var(--color-text-muted); }
  .terminal .term-accent { color: var(--color-accent); font-weight: 600; }
</style>

<style>
  .terminal-section {
    border-bottom: 1px solid var(--color-border);
  }

  .terminal-inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-block: var(--space-24);
    padding-inline: var(--space-6);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--font-size-4xl);
    font-weight: 300;
    letter-spacing: var(--tracking-tight);
    line-height: 1.1;
    color: var(--color-text);
    margin: 0 0 var(--space-4);
    font-optical-sizing: auto;
    max-width: 22ch;
  }

  .section-lede {
    font-family: var(--font-body);
    font-size: var(--font-size-md);
    color: var(--color-text-muted);
    max-width: var(--content-max);
    margin: 0 0 var(--space-12);
    line-height: 1.6;
  }

  .terminal {
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    max-width: 48rem;
  }

  .terminal-body {
    margin: 0;
    padding: var(--space-6);
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    line-height: 1.7;
    color: var(--color-text);
    background: var(--color-surface-raised);
    border: none;
    border-radius: 0;
    overflow-x: auto;
  }
</style>
