---
import FeatureCard from '../molecules/FeatureCard.astro';

interface Feature {
  icon: string;
  title: string;
  body: string;
  href?: string;
}

interface Props {
  title?: string;
  lede?: string;
  features: Feature[];
  columns?: 2 | 3;
}

const { title, lede, features, columns = 3 } = Astro.props;
---

<section class="features-section">
  <div class="features-inner">
    {title && (
      <h2 class="section-title" data-animate="fade-up">{title}</h2>
    )}
    {lede && (
      <p class="section-lede" data-animate="fade-up">{lede}</p>
    )}

    <div class:list={['feature-grid', `feature-grid--${columns}col`]}>
      {features.map((feature) => (
        <FeatureCard icon={feature.icon} title={feature.title} href={feature.href}>
          {feature.body}
        </FeatureCard>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    border-bottom: 1px solid var(--color-border);
  }

  .features-inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-block: var(--space-24);
    padding-inline: var(--space-6);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--font-size-4xl);
    font-weight: 300;
    letter-spacing: var(--tracking-tight);
    line-height: 1.1;
    color: var(--color-text);
    margin: 0 0 var(--space-4);
    font-optical-sizing: auto;
    max-width: 22ch;
  }

  .section-lede {
    font-family: var(--font-body);
    font-size: var(--font-size-md);
    color: var(--color-text-muted);
    max-width: var(--content-max);
    margin: 0 0 var(--space-12);
    line-height: 1.6;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .feature-grid--2col,
    .feature-grid--3col {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .feature-grid--3col {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
