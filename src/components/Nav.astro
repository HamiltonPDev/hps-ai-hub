---
type NavLink = { href: string; label: string; soon?: boolean };
type NavDropdown = { label: string; items: NavLink[] };
type NavEntry = NavLink | NavDropdown;

function isDropdown(e: NavEntry): e is NavDropdown {
  return 'items' in e;
}

const navEntries: NavEntry[] = [
  { href: '/', label: 'Home' },
  {
    label: 'Concepts',
    items: [
      { href: '/architecture', label: 'Architecture' },
      { href: '/workflow', label: 'Workflow' },
      { href: '/runtime', label: 'Runtime' },
      { href: '/manifesto', label: 'Manifesto' },
      { href: '/ecosystem', label: 'Ecosystem' },
    ],
  },
  {
    label: 'Library',
    items: [
      { href: '/agents', label: 'Agents' },
      { href: '/models', label: 'Models' },
      { href: '/skills', label: 'Skills' },
      { href: '/domains', label: 'Domains' },
    ],
  },
  {
    label: 'Tools',
    items: [
      { href: '/omo', label: 'OmO' },
      { href: '/engram', label: 'Engram' },
      { href: '/agent-teams-lite', label: 'agent-teams-lite' },
      { href: '/gentle-ai', label: 'gentle-ai' },
      { href: '/gga', label: 'GGA' },
    ],
  },
  {
    label: 'Resources',
    items: [
      { href: '/setup', label: 'Setup' },
      { href: '/reference', label: 'Reference' },
      { href: '/roadmap', label: 'Roadmap' },
      { href: '/explore', label: 'Explore' },
      { href: '/news', label: 'News' },
      { href: '/coming-soon', label: 'Coming Soon' },
    ],
  },
];

const currentPath = Astro.url.pathname;

function isGroupActive(entry: NavEntry): boolean {
  if (!isDropdown(entry)) return currentPath === entry.href;
  return entry.items.some(item => !item.soon && item.href === currentPath);
}
---

<header class="nav-header">
  <nav aria-label="Main navigation" class="nav-inner">
    <div class="nav-container">
      <a href="/" class="nav-logo">HPS·AI</a>
      <button
        class="nav-toggle"
        aria-label="Toggle navigation"
        aria-expanded="false"
        aria-controls="nav-menu"
        type="button"
      >
        <span class="nav-toggle-line"></span>
        <span class="nav-toggle-line"></span>
        <span class="nav-toggle-line"></span>
      </button>
      <ul class="nav-links" id="nav-menu" role="list">
        {navEntries.map(entry => (
          isDropdown(entry) ? (
            <li class="nav-item has-dropdown" data-active={isGroupActive(entry) ? 'true' : 'false'} data-open="false">
              <button
                class="nav-link nav-trigger"
                aria-haspopup="true"
                aria-expanded="false"
                type="button"
              >
                {entry.label}
                <span class="nav-chevron" aria-hidden="true">▾</span>
              </button>
              <ul class="nav-dropdown" role="list">
                {entry.items.map(item => (
                  <li>
                    <a
                      href={item.soon ? '#' : item.href}
                      class:list={['nav-dropdown-link', { 'is-soon': item.soon }]}
                      aria-current={!item.soon && currentPath === item.href ? 'page' : undefined}
                      aria-disabled={item.soon ? 'true' : undefined}
                      tabindex={item.soon ? -1 : undefined}
                    >
                      <span class="nav-dropdown-label">{item.label}</span>
                      {item.soon && <span class="nav-soon-badge">soon</span>}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          ) : (
            <li class="nav-item">
              <a
                href={entry.href}
                class="nav-link"
                aria-current={currentPath === entry.href ? 'page' : undefined}
              >
                {entry.label}
              </a>
            </li>
          )
        ))}
      </ul>
    </div>
  </nav>
</header>

<script>
  // Progressive enhancement: hamburger + click-to-toggle dropdowns + outside-click close
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const menu = document.getElementById('nav-menu');
  const triggers = document.querySelectorAll<HTMLButtonElement>('.nav-trigger');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
  }

  triggers.forEach(trigger => {
    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      const item = trigger.closest<HTMLLIElement>('.nav-item');
      if (!item) return;
      const isOpen = item.getAttribute('data-open') === 'true';
      document.querySelectorAll<HTMLLIElement>('.nav-item[data-open="true"]').forEach(other => {
        if (other !== item) {
          other.setAttribute('data-open', 'false');
          const t = other.querySelector('.nav-trigger');
          if (t) t.setAttribute('aria-expanded', 'false');
        }
      });
      item.setAttribute('data-open', isOpen ? 'false' : 'true');
      trigger.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  document.addEventListener('click', (e) => {
    const target = e.target as Element | null;
    if (!target?.closest('.nav-item')) {
      document.querySelectorAll<HTMLLIElement>('.nav-item[data-open="true"]').forEach(item => {
        item.setAttribute('data-open', 'false');
        const t = item.querySelector('.nav-trigger');
        if (t) t.setAttribute('aria-expanded', 'false');
      });
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelectorAll<HTMLLIElement>('.nav-item[data-open="true"]').forEach(item => {
        item.setAttribute('data-open', 'false');
        const t = item.querySelector('.nav-trigger');
        if (t) t.setAttribute('aria-expanded', 'false');
      });
      if (menu?.classList.contains('is-open')) {
        menu.classList.remove('is-open');
        toggle?.setAttribute('aria-expanded', 'false');
      }
    }
  });
</script>

<style>
  .nav-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-background);
    backdrop-filter: blur(8px);
  }

  .nav-container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-block: var(--space-4);
    padding-inline: var(--space-6);
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .nav-logo {
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    flex-shrink: 0;
    transition: color var(--duration-quick) var(--ease-standard);
  }

  .nav-logo:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  /* ── Hamburger (mobile only) ──────────────────────────────────────── */

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    margin-left: auto;
    flex-direction: column;
    gap: 4px;
  }

  .nav-toggle-line {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--color-text);
    border-radius: 1px;
    transition: transform var(--duration-quick) var(--ease-standard);
  }

  .nav-toggle[aria-expanded="true"] .nav-toggle-line:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle-line:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle-line:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* ── Links container ──────────────────────────────────────────────── */

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
  }

  .nav-item {
    position: relative;
  }

  /* ── Link / trigger base ───────────────────────────────────────────── */

  .nav-link,
  .nav-trigger {
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
    font-weight: 400;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    white-space: nowrap;
    transition: color var(--duration-quick) var(--ease-standard);
    background: none;
    border: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
  }

  .nav-link:hover,
  .nav-trigger:hover {
    color: var(--color-text);
  }

  .nav-link:focus-visible,
  .nav-trigger:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 4px;
  }

  .nav-link[aria-current="page"] {
    color: var(--color-accent);
  }

  .nav-item[data-active="true"] > .nav-trigger {
    color: var(--color-text);
  }

  .nav-chevron {
    margin-left: var(--space-1);
    font-size: 0.7em;
    opacity: 0.6;
    transition: transform var(--duration-quick) var(--ease-standard);
  }

  .nav-item[data-open="true"] .nav-chevron {
    transform: rotate(180deg);
  }

  /* ── Dropdown panel ────────────────────────────────────────────────── */

  .nav-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 13rem;
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-2);
    list-style: none;
    margin: var(--space-2) 0 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition:
      opacity var(--duration-quick) var(--ease-standard),
      transform var(--duration-quick) var(--ease-standard),
      visibility 0s linear var(--duration-quick);
    z-index: 100;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  @media (min-width: 768px) {
    .has-dropdown:hover .nav-dropdown,
    .has-dropdown:focus-within .nav-dropdown {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
      transition-delay: 0s;
    }
  }

  .nav-item[data-open="true"] .nav-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition-delay: 0s;
  }

  .nav-dropdown-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    transition:
      color var(--duration-quick) var(--ease-standard),
      background var(--duration-quick) var(--ease-standard);
  }

  .nav-dropdown-link:hover {
    color: var(--color-text);
    background: var(--color-surface);
  }

  .nav-dropdown-link:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 2px;
  }

  .nav-dropdown-link[aria-current="page"] {
    color: var(--color-accent);
  }

  .nav-dropdown-link.is-soon {
    color: var(--color-text-subtle);
    cursor: not-allowed;
    pointer-events: none;
  }

  .nav-soon-badge {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 0 var(--space-2);
    opacity: 0.8;
  }

  /* ── Mobile ───────────────────────────────────────────────────────── */

  @media (max-width: 767px) {
    .nav-toggle {
      display: flex;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-background);
      border-bottom: 1px solid var(--color-border);
      flex-direction: column;
      align-items: stretch;
      padding: var(--space-4);
      gap: var(--space-1);
      max-height: calc(100vh - 64px);
      overflow-y: auto;
    }

    .nav-links.is-open {
      display: flex;
    }

    .nav-item {
      width: 100%;
    }

    .nav-link,
    .nav-trigger {
      width: 100%;
      justify-content: space-between;
      padding: var(--space-3) var(--space-3);
    }

    .nav-dropdown {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      border: none;
      box-shadow: none;
      padding: 0 0 0 var(--space-4);
      margin-top: 0;
      background: transparent;
      display: none;
    }

    .nav-item[data-open="true"] .nav-dropdown {
      display: flex;
    }

    .nav-dropdown-link {
      padding: var(--space-2) var(--space-3);
    }
  }
</style>
