---
type NavLink = { href: string; label: string; disabled?: boolean; todo?: string };

const navLinks: NavLink[] = [
  { href: '/', label: 'Home' },
  { href: '/architecture', label: 'Architecture' },
  { href: '/agents', label: 'Agents' },
  { href: '/models', label: 'Models' },
  { href: '/explore', label: 'Explore' },
  { href: '/news', label: 'News' },
  // Placeholders — each replaced by its owning content-migration sub-change.
  // Each line has a unique TODO marker so downstream sub-changes can rg+Edit.
  { href: '/skills', label: 'Skills' },
  { href: '/ecosystem', label: 'Ecosystem' },
  { href: '/workflow', label: 'Workflow' },
  { href: '/runtime', label: 'Runtime' },
  { href: '#', label: 'Roadmap',   disabled: true, todo: 'content-migration-8'  }, // TODO(content-migration-8)
  { href: '/setup', label: 'Setup' },
  { href: '/reference', label: 'Reference' },
  { href: '#', label: 'Domains',   disabled: true, todo: 'content-migration-11' }, // TODO(content-migration-11)
];

const currentPath = Astro.url.pathname;
---

<header class="nav-header">
  <nav aria-label="Main navigation" class="nav-inner">
    <div class="nav-container">
      <a href="/" class="nav-logo">HPS·AI</a>
      <ul class="nav-links" role="list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.disabled ? '#' : link.href}
              class="nav-link"
              aria-current={!link.disabled && currentPath === link.href ? 'page' : undefined}
              aria-disabled={link.disabled ? 'true' : undefined}
              tabindex={link.disabled ? -1 : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<style>
  .nav-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-background);
    backdrop-filter: blur(8px);
  }

  .nav-inner {
    /* full-width inner — container constrains content */
  }

  .nav-container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-block: var(--space-4);
    padding-inline: var(--space-6);
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .nav-logo {
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    flex-shrink: 0;
    transition: color var(--duration-quick) var(--ease-standard);
  }

  .nav-logo:hover {
    color: var(--color-text);
  }

  .nav-logo:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
    margin: 0;
    padding: 0;
    overflow-x: auto;
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
    font-weight: 400;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    white-space: nowrap;
    transition: color var(--duration-quick) var(--ease-standard);
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .nav-link[aria-current="page"] {
    color: var(--color-accent);
  }

  .nav-link:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 4px;
  }

  .nav-link[aria-disabled="true"] {
    opacity: 0.35;
    cursor: not-allowed;
    pointer-events: none;
  }
</style>
